generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  phone     String?
  city      String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id            String    @id @default(cuid())
  slug          String    @unique
  nameUz        String
  nameRu        String
  nameEn        String
  descriptionUz String?
  descriptionRu String?
  descriptionEn String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  products      Product[]
}

model Product {
  id                 String   @id @default(cuid())
  sku                String   @unique
  slug               String   @unique
  nameUz             String
  nameRu             String
  nameEn             String
  shortDescriptionUz String?
  shortDescriptionRu String?
  shortDescriptionEn String?
  descriptionUz      String?
  descriptionRu      String?
  descriptionEn      String?
  featureUz          String?
  featureRu          String?
  featureEn          String?
  ingredientsUz      String?
  ingredientsRu      String?
  ingredientsEn      String?
  usageUz            String?
  usageRu            String?
  usageEn            String?
  storeImageUrl      String?
  storeLocationUz    String?
  storeLocationRu    String?
  storeLocationEn    String?
  storeContactsUz    String?
  storeContactsRu    String?
  storeContactsEn    String?
  skinTypes          String?
  size               String?
  price              Int
  hidePrice          Boolean  @default(false)
  stock              Int      @default(0)
  active             Boolean  @default(true)
  isBestseller       Boolean  @default(false)
  homeSortOrder      Int      @default(0)
  imageUrl           String?
  colorFrom          String?
  colorTo            String?
  categoryId         String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  category           Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  galleryImages      ProductGalleryImage[]
  reviews            ProductReview[]
}

model ProductGalleryImage {
  id        String   @id @default(cuid())
  imageUrl  String
  sortOrder Int      @default(0)
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductReview {
  id         String   @id @default(cuid())
  authorName String
  body       String
  rating     Int      @default(5)
  active     Boolean  @default(true)
  productId  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

enum GalleryItemType {
  IMAGE
  VIDEO
}

model SiteSettings {
  id                     String   @id @default(cuid())
  brandName              String   @default("Modaily")
  hideCommerce           Boolean  @default(false)
  announcementTextUz     String?
  announcementTextRu     String?
  announcementTextEn     String?
  announcementLinkLabelUz String?
  announcementLinkLabelRu String?
  announcementLinkLabelEn String?
  announcementLink       String?
  footerPhone            String?
  footerEmail            String?
  footerTelegram         String?
  footerTelegramLink     String?
  footerInstagram        String?
  footerInstagramLink    String?
  storeAddress           String?
  storeMapLink           String?
  footerAddressUz        String?
  footerAddressRu        String?
  footerAddressEn        String?
  newsletterTitleUz      String?
  newsletterTitleRu      String?
  newsletterTitleEn      String?
  newsletterPlaceholderUz String?
  newsletterPlaceholderRu String?
  newsletterPlaceholderEn String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model HomeHero {
  id               String   @id @default(cuid())
  badgeUz          String?
  badgeRu          String?
  badgeEn          String?
  titleUz          String
  titleRu          String
  titleEn          String
  descriptionUz    String?
  descriptionRu    String?
  descriptionEn    String?
  primaryCtaUz     String?
  primaryCtaRu     String?
  primaryCtaEn     String?
  primaryCtaLink   String?
  secondaryCtaUz   String?
  secondaryCtaRu   String?
  secondaryCtaEn   String?
  secondaryCtaLink String?
  imageUrl         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model HomePromoCard {
  id             String   @id @default(cuid())
  titleUz        String
  titleRu        String
  titleEn        String
  descriptionUz  String?
  descriptionRu  String?
  descriptionEn  String?
  buttonLabelUz  String?
  buttonLabelRu  String?
  buttonLabelEn  String?
  buttonLink     String?
  imageUrl       String?
  sortOrder      Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model HomeAboutSection {
  id                  String   @id @default(cuid())
  titleUz             String
  titleRu             String
  titleEn             String
  descriptionUz       String?
  descriptionRu       String?
  descriptionEn       String?
  secondaryTitleUz    String?
  secondaryTitleRu    String?
  secondaryTitleEn    String?
  secondaryDescriptionUz String?
  secondaryDescriptionRu String?
  secondaryDescriptionEn String?
  bottomDescriptionUz String?
  bottomDescriptionRu String?
  bottomDescriptionEn String?
  imageUrl            String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model GalleryItem {
  id             String          @id @default(cuid())
  type           GalleryItemType
  titleUz        String?
  titleRu        String?
  titleEn        String?
  descriptionUz  String?
  descriptionRu  String?
  descriptionEn  String?
  imageUrl       String
  videoUrl       String?
  sortOrder      Int             @default(0)
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Testimonial {
  id               String   @id @default(cuid())
  authorName       String
  authorRoleUz     String?
  authorRoleRu     String?
  authorRoleEn     String?
  productNameUz    String?
  productNameRu    String?
  productNameEn    String?
  bodyUz           String
  bodyRu           String
  bodyEn           String
  avatarUrl        String?
  rating           Int      @default(5)
  sortOrder        Int      @default(0)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
