generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  phone     String?
  city      String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  fullName  String
  phone     String
  message   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model Category {
  id            String    @id @default(cuid())
  slug          String    @unique
  nameUz        String
  nameRu        String
  nameEn        String
  descriptionUz String?
  descriptionRu String?
  descriptionEn String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  products      Product[]
}

model SkinTypeOption {
  id        String   @id @default(cuid())
  value     String   @unique
  nameUz    String
  nameRu    String
  nameEn    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model Product {
  id                 String   @id @default(cuid())
  sku                String   @unique
  slug               String   @unique
  nameUz             String
  nameRu             String
  nameEn             String
  shortDescriptionUz String?
  shortDescriptionRu String?
  shortDescriptionEn String?
  descriptionUz      String?
  descriptionRu      String?
  descriptionEn      String?
  featureUz          String?
  featureRu          String?
  featureEn          String?
  ingredientsUz      String?
  ingredientsRu      String?
  ingredientsEn      String?
  usageUz            String?
  usageRu            String?
  usageEn            String?
  storeImageUrl      String?
  storeLocationUz    String?
  storeLocationRu    String?
  storeLocationEn    String?
  storeContactsUz    String?
  storeContactsRu    String?
  storeContactsEn    String?
  skinTypes          String?
  categoryIds        String?
  size               String?
  price              Int
  discountAmount     Int      @default(0)
  hidePrice          Boolean  @default(false)
  stock              Int      @default(0)
  active             Boolean  @default(true)
  isBestseller       Boolean  @default(false)
  isHit              Boolean  @default(false)
  isNew              Boolean  @default(false)
  homeSortOrder      Int      @default(0)
  imageUrl           String?
  colorFrom          String?
  colorTo            String?
  categoryId         String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  category           Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  galleryImages      ProductGalleryImage[]
  heroEntries        HomeHero[] @relation("HomeHeroProduct")
  promoEntries       HomePromoCard[] @relation("HomePromoCardProduct")
  linkedBlogPosts    BlogPost[] @relation("BlogPostLinkedProduct")
  recommendationLinks ProductRecommendation[] @relation("ProductRecommendationSource")
  recommendedByLinks ProductRecommendation[] @relation("ProductRecommendationTarget")
  reviews            ProductReview[]
}

model ProductRecommendation {
  id                   String   @id @default(cuid())
  sourceProductId      String
  recommendedProductId String
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  sourceProduct        Product  @relation("ProductRecommendationSource", fields: [sourceProductId], references: [id], onDelete: Cascade)
  recommendedProduct   Product  @relation("ProductRecommendationTarget", fields: [recommendedProductId], references: [id], onDelete: Cascade)

  @@unique([sourceProductId, recommendedProductId])
  @@index([sourceProductId, sortOrder])
  @@index([recommendedProductId])
}

model ProductGalleryImage {
  id        String   @id @default(cuid())
  type      GalleryItemType @default(IMAGE)
  imageUrl  String?
  videoUrl  String?
  sortOrder Int      @default(0)
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductReview {
  id         String   @id @default(cuid())
  authorName String
  body       String
  rating     Int      @default(5)
  active     Boolean  @default(true)
  productId  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

enum GalleryItemType {
  IMAGE
  VIDEO
}

model SiteSettings {
  id                     String   @id @default(cuid())
  brandName              String   @default("Modaily")
  hideCommerce           Boolean  @default(false)
  announcementTextUz     String?
  announcementTextRu     String?
  announcementTextEn     String?
  announcementLinkLabelUz String?
  announcementLinkLabelRu String?
  announcementLinkLabelEn String?
  announcementLink       String?
  footerPhone            String?
  footerEmail            String?
  footerTelegram         String?
  footerTelegramLink     String?
  footerInstagram        String?
  footerInstagramLink    String?
  storeAddress           String?
  storeMapLink           String?
  footerAddressUz        String?
  footerAddressRu        String?
  footerAddressEn        String?
  aboutTitleUz          String?
  aboutTitleRu          String?
  aboutTitleEn          String?
  aboutDescriptionUz    String?
  aboutDescriptionRu    String?
  aboutDescriptionEn    String?
  aboutBrandTitleUz     String?
  aboutBrandTitleRu     String?
  aboutBrandTitleEn     String?
  aboutPanelDescriptionUz String?
  aboutPanelDescriptionRu String?
  aboutPanelDescriptionEn String?
  aboutPanelSecondaryDescriptionUz String?
  aboutPanelSecondaryDescriptionRu String?
  aboutPanelSecondaryDescriptionEn String?
  aboutImageUrl         String?
  newsletterTitleUz      String?
  newsletterTitleRu      String?
  newsletterTitleEn      String?
  newsletterPlaceholderUz String?
  newsletterPlaceholderRu String?
  newsletterPlaceholderEn String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model ShopLocation {
  id           String            @id @default(cuid())
  address      String
  mapLink      String?
  active       Boolean           @default(true)
  sortOrder    Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  workingHours ShopWorkingHour[]

  @@index([active, sortOrder])
}

model ShopWorkingHour {
  id             String       @id @default(cuid())
  label          String?
  value          String
  sortOrder      Int          @default(0)
  shopLocationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  shopLocation   ShopLocation @relation(fields: [shopLocationId], references: [id], onDelete: Cascade)

  @@index([shopLocationId, sortOrder])
}

model HomeHero {
  id               String   @id @default(cuid())
  badgeUz          String?
  badgeRu          String?
  badgeEn          String?
  titleUz          String
  titleRu          String
  titleEn          String
  descriptionUz    String?
  descriptionRu    String?
  descriptionEn    String?
  primaryCtaUz     String?
  primaryCtaRu     String?
  primaryCtaEn     String?
  primaryCtaLink   String?
  secondaryCtaUz   String?
  secondaryCtaRu   String?
  secondaryCtaEn   String?
  secondaryCtaLink String?
  imageUrl         String?
  mobileImageUrl   String?
  heroProductId    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  heroProduct      Product? @relation("HomeHeroProduct", fields: [heroProductId], references: [id], onDelete: SetNull)
}

model HomePromoCard {
  id             String   @id @default(cuid())
  titleUz        String
  titleRu        String
  titleEn        String
  descriptionUz  String?
  descriptionRu  String?
  descriptionEn  String?
  buttonLabelUz  String?
  buttonLabelRu  String?
  buttonLabelEn  String?
  buttonLink     String?
  imageUrl       String?
  promoProductId String?
  sortOrder      Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  promoProduct   Product? @relation("HomePromoCardProduct", fields: [promoProductId], references: [id], onDelete: SetNull)
}

model HomeAboutSection {
  id                  String   @id @default(cuid())
  titleUz             String
  titleRu             String
  titleEn             String
  descriptionUz       String?
  descriptionRu       String?
  descriptionEn       String?
  secondaryTitleUz    String?
  secondaryTitleRu    String?
  secondaryTitleEn    String?
  secondaryDescriptionUz String?
  secondaryDescriptionRu String?
  secondaryDescriptionEn String?
  bottomDescriptionUz String?
  bottomDescriptionRu String?
  bottomDescriptionEn String?
  imageUrl            String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model GalleryItem {
  id             String          @id @default(cuid())
  type           GalleryItemType
  titleUz        String?
  titleRu        String?
  titleEn        String?
  descriptionUz  String?
  descriptionRu  String?
  descriptionEn  String?
  imageUrl       String
  videoUrl       String?
  sortOrder      Int             @default(0)
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model GallerySectionHeading {
  id        String          @id @default(cuid())
  type      GalleryItemType
  textUz    String?
  textRu    String?
  textEn    String?
  sortOrder Int             @default(0)
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model Testimonial {
  id               String   @id @default(cuid())
  authorName       String
  authorRoleUz     String?
  authorRoleRu     String?
  authorRoleEn     String?
  productNameUz    String?
  productNameRu    String?
  productNameEn    String?
  bodyUz           String
  bodyRu           String
  bodyEn           String
  avatarUrl        String?
  rating           Int      @default(5)
  sortOrder        Int      @default(0)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model BlogPost {
  id               String            @id @default(cuid())
  cardTitle        String
  cardTitleUz      String?
  cardTitleRu      String?
  cardTitleEn      String?
  excerpt          String
  excerptUz        String?
  excerptRu        String?
  excerptEn        String?
  coverImage       String
  publishDate      DateTime
  category         String
  categoryUz       String?
  categoryRu       String?
  categoryEn       String?
  slug             String            @unique
  featured         Boolean           @default(false)
  linkedProductId  String?
  mainTitle        String
  mainTitleUz      String?
  mainTitleRu      String?
  mainTitleEn      String?
  introDescription String
  introDescriptionUz String?
  introDescriptionRu String?
  introDescriptionEn String?
  seoTitle         String
  metaDescription  String
  dynamicSections  BlogPostSection[]
  media            BlogPostMedia[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  linkedProduct    Product?          @relation("BlogPostLinkedProduct", fields: [linkedProductId], references: [id], onDelete: SetNull)

  @@index([publishDate(sort: Desc)])
  @@index([category, publishDate(sort: Desc)])
  @@index([featured, publishDate(sort: Desc)])
  @@index([linkedProductId])
}

model BlogPostMedia {
  id        String          @id @default(cuid())
  type      GalleryItemType @default(IMAGE)
  imageUrl  String?
  videoUrl  String?
  sortOrder Int             @default(0)
  postId    String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  post      BlogPost        @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, sortOrder])
}

model BlogPostSection {
  id          String   @id @default(cuid())
  title       String
  titleUz     String?
  titleRu     String?
  titleEn     String?
  description String
  descriptionUz String?
  descriptionRu String?
  descriptionEn String?
  sortOrder   Int      @default(0)
  postId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  post        BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, sortOrder])
}
