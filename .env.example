DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-STHS16KXCK"

# Media storage provider. Keep empty/local legacy uploads unchanged until upload routes are migrated.
# Supported foundation provider: r2
MEDIA_STORAGE_PROVIDER="r2"

# Cloudflare R2 S3-compatible API credentials.
# Create a scoped R2 API token with object read/write access only for the target bucket.
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET="modaily-media-production"

# Optional override. Defaults to https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ENDPOINT=""
CLOUDFLARE_R2_REGION="auto"

# Public CDN/custom-domain base URL for objects, without a trailing slash.
# Example: https://media.modaily.uk
CLOUDFLARE_R2_PUBLIC_BASE_URL=""

# Legacy local upload override. Existing local upload routes still support this.
# If unset, they use /data/uploads in Docker/Railway or public/uploads locally.
UPLOAD_DIR=""

# Experimental HLS pipeline. Keep token secret; this route is not connected to the frontend yet.
HLS_EXPERIMENT_TOKEN=""
HLS_WORK_DIR=""
HLS_MAX_INPUT_BYTES="524288000"
HLS_WORKER_POLL_INTERVAL_MS="5000"
HLS_JOB_TIMEOUT_MS="1800000"
HLS_JOB_STALE_MS="1800000"
HLS_JOB_MAX_ATTEMPTS="3"
FFMPEG_PATH="ffmpeg"
FFPROBE_PATH="ffprobe"

# Experimental direct-to-R2 browser uploads. Disabled by default; legacy upload routes remain active.
EXPERIMENTAL_DIRECT_UPLOADS_ENABLED="false"
NEXT_PUBLIC_EXPERIMENTAL_DIRECT_UPLOADS="false"
DIRECT_UPLOAD_URL_EXPIRES_SECONDS="600"
DIRECT_UPLOAD_MAX_VIDEO_BYTES="262144000"
DIRECT_UPLOAD_PRODUCT_VIDEO_MAX_BYTES="262144000"
DIRECT_UPLOAD_GALLERY_VIDEO_MAX_BYTES="262144000"
DIRECT_UPLOAD_PROMO_VIDEO_MAX_BYTES="262144000"

# Server-only Telegram notifications. Keep token and chat IDs secret.
# TELEGRAM_CHAT_ID is a shared fallback; review/contact-specific IDs override it.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_REVIEW_CHAT_ID=""
TELEGRAM_CONTACT_CHAT_ID=""
